# Copy to ".env" and tweak as needed. All values are optional.

# --- Captions / ASR ---
WHISPER_MODEL=large-v3      # tiny | base | small | medium | large-v3
LANGUAGE=                   # blank = auto-detect; or e.g. en, hi
DEVICE=auto                 # auto | cuda | cpu
COMPUTE_TYPE=auto           # auto | float16 | int8_float16 | int8
BATCH_SIZE=8                # lower this if you hit out-of-memory
ALIGN=true                  # word-level timestamps (needed for Day 2)
VAD_ONSET=0.35              # lower = fewer skipped lines (whisperx default 0.5)
VAD_OFFSET=0.25            # lower = fewer skipped lines (whisperx default 0.363)
NO_SPEECH_THRESHOLD=0.8    # higher = keep more borderline speech (default 0.6)

# --- Audio ---
SAMPLE_RATE=16000

# --- LLM analysis (Day 3) ---
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=            # free key: https://aistudio.google.com/apikey
